{
  "$schema": "https://biomejs.dev/schemas/2.4.11/schema.json",
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "off"
      }
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "performance": {
        "noBarrelFile": "off",
        "noAwaitInLoops": "warn",
        "noDelete": "warn",
        "noNamespaceImport": "warn",
        "useTopLevelRegex": "warn"
      },
      "complexity": "off",
      "suspicious": {
        "noExplicitAny": "off",
        "noNonNullAssertedOptionalChain": "off"
      },
      "correctness": {
        "noUnusedVariables": "off"
      },
      "style": {
        "useNodejsImportProtocol": "off",
        "useImportType": "error"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all",
      "semicolons": "asNeeded"
    }
  },
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "**",
      "!src/polyfills",
      "!dist",
      "!node_modules",
      "!src-tauri/target",
      "!src-tauri/gen",
      "!target",
      "!src-tauri/src/enhance/builtin/*.js",
      "!scripts/*.mjs",
      "!Cargo.lock",
      "!pnpm-lock.yaml",
      "!README.md",
      "!Changelog.md",
      "!CONTRIBUTING.md",
      "!.changelog_backups",
      "!.github",
      "!.pnpm-lock.yaml"
    ]
  }
}
